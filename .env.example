# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted. Used for self-referential links.
APP_URL="MY_APP_URL"

# MONGODB_URI: Optional connection string to attach a persistent MongoDB cluster (e.g. MongoDB Atlas).
# If omitted, CausalFunnel automatically runs a high-performance local transactional JSON system.
MONGODB_URI=
